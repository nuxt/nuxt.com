# ============================================================================
# Everything in this file is OPTIONAL.
#
# `pnpm dev` works with no .env at all: docs are cloned from GitHub, ecosystem
# APIs (/api/v1/**) are proxied to nuxt.com, a session password is generated
# automatically, and the Nuxi agent is disabled (no Eve runtime is spawned).
#
# Only set the variables below to enable the specific features you work on.
# ============================================================================

# ----------------------------------------------------------------------------
# Docs from local checkouts (optional — remote GitHub clones are used otherwise)
# ----------------------------------------------------------------------------
# Paths to local clones of github.com/nuxt/nuxt (3.x / 4.x / main branches)
NUXT_V3_PATH=
NUXT_V4_PATH=
NUXT_V5_PATH=
# Path to a local clone of github.com/nuxt/examples
NUXT_EXAMPLES_PATH=

# ----------------------------------------------------------------------------
# GitHub login (optional — needed for sign-in, dashboard, chat history, admin)
# ----------------------------------------------------------------------------
# Create a GitHub OAuth app at: https://github.com/settings/applications/new
# Callback URL: http://localhost:3000/api/auth/github
NUXT_OAUTH_GITHUB_CLIENT_ID=
NUXT_OAUTH_GITHUB_CLIENT_SECRET=

# Session encryption password. Auto-generated in dev if unset.
# Generate one with: openssl rand -base64 32
NUXT_SESSION_PASSWORD=

# Comma-separated GitHub logins granted admin role (in addition to Nuxt core team)
NUXT_ADMIN_GITHUB_LOGINS=

# ----------------------------------------------------------------------------
# Nuxi agent (optional — requires `pnpm dev:full`, disabled in default ui-only mode)
# ----------------------------------------------------------------------------
# Vercel AI Gateway key for the agent model: https://vercel.com/ai-gateway
AI_GATEWAY_API_KEY=

# Shared secret between the Nuxt app and the Eve runtime (web + eve Vercel services)
# Generate one with: openssl rand -base64 32
INTERNAL_API_SECRET=

# Canonical site URL for MCP + internal API callbacks (also used for OG images
# when pre-rendering the docs)
NUXT_PUBLIC_SITE_URL=

# nuxt-js team / nuxt project Vercel ids (admin-only Vercel MCP connection).
# Find them in `.vercel/project.json` (orgId / projectId) after `vercel link`.
NUXI_VERCEL_TEAM_ID=
NUXI_VERCEL_PROJECT_ID=

# ----------------------------------------------------------------------------
# GitHub API data (optional — repo stats, contributors, team members)
# ----------------------------------------------------------------------------
# Personal access token to avoid GitHub API rate limits
NUXT_GITHUB_TOKEN=

# ----------------------------------------------------------------------------
# MCP evals (optional — for running `pnpm eval`)
# ----------------------------------------------------------------------------
MCP_URL=http://localhost:3000/mcp

# ----------------------------------------------------------------------------
# Newsletter, sponsors & contact (optional)
# ----------------------------------------------------------------------------
# Newsletter subscription via Resend
NUXT_RESEND_API_KEY=
NUXT_RESEND_AUDIENCE_ID=

# Sponsors list via Open Collective
NUXT_OPEN_COLLECTIVE_API_KEY=

# Contact email used in the site footer and contact forms
NUXT_CONTACT_EMAIL=""

# Turnstile CAPTCHA (contact form verification): https://nuxt.com/modules/turnstile
NUXT_PUBLIC_TURNSTILE_SITE_KEY=
NUXT_TURNSTILE_SECRET_KEY=

# ============================================================================
# Team / production only — not needed for local contributions
# ============================================================================

# Bearer token for /mcp/admin — web service (handler) + eve service (admin-mcp)
NUXT_MCP_ADMIN_TOKEN=

# Vercel Connect Slack client UID — eve service only.
# Local dev and Vercel preview default to slack/nuxi-preview; prod uses slack/nuxi.
SLACK_CONNECTOR=

# Eve scheduled Slack workflows (eve service only)
# Channel names (users.conversations). Optional NUXT_*_SLACK_CHANNEL_ID overrides
# and skips name resolution.
NUXT_WORKFLOW_SLACK_CHANNEL=project-nuxi
# NUXT_WORKFLOW_SLACK_CHANNEL_ID=
NUXT_WORKFLOW_SINCE_DAYS=7
NUXT_FIREHOSE_SLACK_CHANNEL=firehose-nuxt
# NUXT_FIREHOSE_SLACK_CHANNEL_ID=
# Slack workspace subdomain for archive permalinks (https://<workspace>.slack.com/archives/…)
NUXT_SLACK_WORKSPACE=vercel
# Manual trigger on preview: set to 1 to force-enable on prod
NUXT_WORKFLOW_MANUAL_TRIGGER=
